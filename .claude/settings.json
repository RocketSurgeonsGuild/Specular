{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash hooks/scripts/track-telemetry.sh"
          }
        ]
      },
      {
        "type": "command",
        "bash": "bash hooks/scripts/track-telemetry.sh",
        "powershell": "powershell -File hooks/scripts/track-telemetry.ps1"
      }
    ],
    "SessionStart": [
      {
        "matcher": "startup|resume|clear",
        "hooks": [
          {
            "type": "command",
            "command": "\".claude/hooks/superpowers/hooks/run-hook.cmd\" session-start-codex",
            "async": false
          }
        ]
      },
      {
        "matcher": "startup|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "\".claude/hooks/superpowers/hooks/run-hook.cmd\" session-start",
            "async": false
          }
        ]
      }
    ],
    "sessionStart": [
      {
        "command": "./hooks/run-hook.cmd session-start"
      }
    ]
  }
}

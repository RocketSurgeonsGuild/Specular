    <!-- Sample applications (samples/) — central versions, never packed
    (samples/Directory.Build.props sets IsPackable=false). -->
    <ItemGroup>
        <PackageVersion Include="Microsoft.Extensions.DependencyInjection" Version="10.0.9" />
    </ItemGroup>
</Project>

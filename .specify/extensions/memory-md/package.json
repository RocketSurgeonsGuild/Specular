{
  "name": "speckit-memory",
  "version": "0.8.5",
  "private": true,
  "description": "Optional local memory optimizer for Spec Kit Memory Hub.",
  "bin": {
    "speckit-memory": "dist/bin/speckit-memory.js"
  },
  "type": "commonjs",
  "main": "dist/index.js",
  "scripts": {
    "build": "npx -y -p typescript@latest tsc -p tsconfig.json",
    "postbuild": "chmod +x dist/bin/speckit-memory.js",
    "prebuild": "rm -rf node_modules/typescript && npm install typescript@latest",
    "clean": "rm -rf dist",
    "start": "node dist/bin/speckit-memory.js",
    "test-root": "./scripts/test-root-resolution.sh"
  },
  "dependencies": {
    "@dqbd/tiktoken": "^1.0.22",
    "better-sqlite3": "^12.9.0",
    "chalk": "^5.0.0",
    "commander": "^15.0.0",
    "fast-glob": "^3.3.2",
    "gray-matter": "^4.0.3",
    "markdown-it": "^14.1.0",
    "typescript": "^7.0.0",
    "yaml": "^2.6.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^24.0.0"
  },
  "engines": {
    "node": ">=18"
  }
}

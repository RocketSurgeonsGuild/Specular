{
  "metadata": [
    {
      "src": [
        {
          "src": "src",
          "files": ["**/*.csproj"],
          "exclude": ["**/*Analyzers*/**", "**/bin/**", "**/obj/**"]
        }
      ],
      "properties": {
        "Configuration": "Release"
      },
      "dest": "docs/.docfx-metadata/api",
      "namespaceLayout": "flattened",
      "memberLayout": "samePage",
      "disableGitFeatures": true
    }
  ]
}
